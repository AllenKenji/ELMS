PORT=5000

# Option A (recommended on Render): single connection string
DATABASE_URL=postgresql://user:password@host:5432/database

# Option B (local/dev): split database variables
DB_USER=postgres
DB_HOST=localhost
DB_NAME=elegislative
DB_PASS=your_password
DB_PORT=5432

# Auth secrets
JWT_SECRET=replace_with_strong_random_secret
JWT_REFRESH_SECRET=replace_with_another_strong_random_secret

# CORS
CORS_ORIGINS=http://localhost:5173,https://elegislative.lits.com.ph
